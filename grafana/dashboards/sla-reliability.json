      "type": "stat",
      "description": "Average uptime across all targets over the last 365 days. ≥99.9% = three nines (≤8.76 h/year). ≥99.99% = four nines (≤52.6 min/year). On a fresh install this number is warm-up dependent until 365 days of data exist.",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
