  "panels": [
    {
      "title": "SLA — Last 24h",
      "type": "stat",
      "description": "Average uptime across all targets over the last 24 hours. ≥99.9% = three nines (≤1.4 min/day). ≥99.99% = four nines (≤8.6 sec/day).",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "avg(probe:success_ratio:1d)",
          "legendFormat": "24h SLA",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
