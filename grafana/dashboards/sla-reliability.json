      "type": "stat",
      "description": "Average uptime across all targets over the last 30 days. ≥99.9% = three nines (≤43 min/month). ≥99.99% = four nines (≤4.3 min/month). On a fresh install this number is warm-up dependent until 30 days of data exist.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "avg(probe:success_ratio:30d)",
          "legendFormat": "30d SLA",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "color": { "mode": "thresholds" }
