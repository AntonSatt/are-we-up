global:
  resolve_timeout: 5m

# Notification templates
templates: []

route:
  receiver: default
  group_by:
    - alertname
    - instance
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h

  routes:
    # Critical alerts go to all configured receivers
    - match:
        severity: critical
      receiver: critical
      group_wait: 10s
      repeat_interval: 1h

    # Warning alerts use default receiver
    - match:
        severity: warning
      receiver: default

receivers:
  - name: default
    webhook_configs:
      - url: "http://discord-bridge:9094"
        send_resolved: true

  - name: critical
    webhook_configs:
      - url: "http://discord-bridge:9094"
        send_resolved: true

# Inhibit lower-severity alerts when critical alert fires for same instance
inhibit_rules:
  - source_match:
      severity: critical
    target_match:
      severity: warning
    equal:
      - alertname
      - instance
